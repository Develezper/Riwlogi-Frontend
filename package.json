{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "packageManager": "bun@1.3.9",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "bun test tests/unit --preload ./tests/setup.js",
    "test:coverage": "bun test tests/unit --preload ./tests/setup.js --coverage",
    "test:watch": "bun test tests/unit --preload ./tests/setup.js --watch",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "lint": "eslint --concurrency=auto .",
    "lint:fix": "eslint --concurrency=auto --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "bun run lint && bun run test && bun run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "eslint --concurrency=auto --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@happy-dom/global-registrator": "^20.8.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "eslint": "^10.0.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "tailwindcss": "^4.1.18",
    "vite": "8.0.0-beta.0"
  },
  "overrides": {
    "vite": "8.0.0-beta.0",
    "@codemirror/language": "6.12.2",
    "@codemirror/state": "6.5.4",
    "@codemirror/view": "6.39.14"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.14",
    "codemirror": "^6.0.2",
    "gsap": "^3.14.2",
    "marked": "^17.0.2"
  }
}